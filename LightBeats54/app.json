{
  "expo": {
    "name": "LightBeats",
    "slug": "LightBeats",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lightbeats",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "LightBeats necesita acceso al micrófono para capturar audio y sincronizar la linterna",
        "NSCameraUsageDescription": "LightBeats necesita acceso a la cámara para controlar la linterna"
      },
      "bundleIdentifier": "com.sebastian.blancoquesada.LightBeats"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "package": "com.sebastian.blancoquesada.LightBeats"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "LightBeats necesita acceso a la cámara para usar la linterna"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "LightBeats necesita acceso al micrófono para capturar audio"
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
